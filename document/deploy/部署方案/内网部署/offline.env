# Application deployment configuration used by start-offline.sh and rollback-offline.sh.

# ================= Application =================
ENV=prod
REPO_NAME=java-template
APP_PORT=18080
APP_LOG_DIR=/data/java-template/logs
APP_MEMORY_LIMIT=1G
APP_MEMORY_RESERVATION=512M
IMAGE_KEEP_COUNT=3

# APP_IMAGE is generated into app-image.env by start-offline.sh.
# Override it only when you want to start a specific image manually.
# APP_IMAGE=java-template:prod-20260608120000-abcdef0

# ================= Jar build =================
# Runtime base image must already exist on the intranet server.
RUNTIME_IMAGE=eclipse-temurin:21-jre

# Put uploaded jar files here, or pass the jar path to start-offline.sh.
JAR_DIR=jars
# JAR_FILE=jars/jackal-java-template.jar
