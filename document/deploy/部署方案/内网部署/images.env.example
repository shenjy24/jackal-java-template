# Copy this file to images.env before running load-images.sh.

# Directory relative to the deployment root, or use absolute paths in *_IMAGE_TAR.
IMAGE_DIR=images

# MySQL image prepared outside the application release package.
MYSQL_IMAGE=mysql:8.4
MYSQL_IMAGE_TAR=images/mysql-8.4.tar

# Java runtime base image used by Dockerfile.
LOAD_RUNTIME_IMAGE=1
RUNTIME_IMAGE=eclipse-temurin:21-jre
RUNTIME_IMAGE_TAR=images/eclipse-temurin-21-jre.tar

# Nginx is optional. Keep LOAD_NGINX_IMAGE=0 if the intranet deployment does not use Nginx.
LOAD_NGINX_IMAGE=0
NGINX_IMAGE=nginx:stable
NGINX_IMAGE_TAR=images/nginx-stable.tar
