# Deployment configuration used by start.sh and rollback.sh.

# ================= Deploy =================
ENV=prod
BRANCH_NAME=main
REPO_NAME=java-template

# ================= Application =================
APP_PORT=18080
APP_LOG_DIR=../logs
APP_MEMORY_LIMIT=1G
APP_MEMORY_RESERVATION=512M

# Keep the latest N production images after each deployment.
IMAGE_KEEP_COUNT=3

# Normally generated from REPO_NAME and ENV.
# Override only when you need custom names.
# APP_CONTAINER_NAME=java-template-prod
# COMPOSE_PROJECT_NAME=java-template-prod
# SPRING_PROFILES_ACTIVE=prod
