# Application deployment configuration used by deploy.sh and rollback.sh.

# ================= Application =================
ENV=prod
REPO_NAME=java-template
APP_PORT=18080
# Relative paths are resolved from the deploy directory.
APP_LOG_DIR=../logs
APP_MEMORY_LIMIT=1G
APP_MEMORY_RESERVATION=512M
IMAGE_KEEP_COUNT=3

# APP_IMAGE is generated into app-image.env by deploy.sh.
# Override it only when you want to start a specific image manually.
# APP_IMAGE=java-template:prod-20260608120000-abcdef0

# ================= Jar build =================
# Runtime base image must already exist on the intranet server.
RUNTIME_IMAGE=eclipse-temurin:21-jre

# Put uploaded jar files in the same directory as deploy.sh by default,
# or pass the jar path to deploy.sh.
JAR_DIR=.
# JAR_FILE=jackal-java-template.jar
